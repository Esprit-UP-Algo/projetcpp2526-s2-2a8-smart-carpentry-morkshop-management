<?xml version="1.0" encoding="UTF-8"?>
<ui version="4.0">
<class>MainWindow</class>
<widget class="QMainWindow" name="MainWindow">
 <property name="geometry">
  <rect>
   <x>0</x>
   <y>0</y>
   <width>1200</width>
   <height>750</height>
  </rect>
 </property>
 <property name="windowTitle">
  <string>Smart Carpentry - Gestion des Commandes</string>
 </property>
 <property name="styleSheet">
  <string notr="true">
    QMainWindow { background-color: #F5EBE0; }
    QWidget { background-color: #F5EBE0; color: #3D2817; font-family: 'Segoe UI', Arial, sans-serif; }
    QTabWidget::pane { border: 2px solid #8B5A2B; background-color: #F5EBE0; border-radius: 5px; }
    QTabBar::tab { background-color: #C9B59A; color: #3D2817; padding: 10px 20px; margin-right: 2px; border-top-left-radius: 5px; border-top-right-radius: 5px; font-weight: bold; }
    QTabBar::tab:selected { background-color: #8B5A2B; color: #F5EBE0; }
    QTabBar::tab:hover { background-color: #9B8068; }
    QGroupBox { background-color: #FFFFFF; border: 2px solid #8B5A2B; border-radius: 8px; margin-top: 15px; padding-top: 15px; font-weight: bold; }
    QGroupBox::title { color: #5D4037; subcontrol-origin: margin; left: 10px; padding: 0 5px; font-size: 10pt; }
    QLineEdit, QTextEdit, QDateEdit, QComboBox, QSpinBox, QDoubleSpinBox { background-color: #FFFFFF; border: 2px solid #C9B59A; border-radius: 5px; padding: 8px; color: #3D2817; font-size: 10pt; }
    QLineEdit:focus, QTextEdit:focus, QDateEdit:focus, QComboBox:focus, QSpinBox:focus, QDoubleSpinBox:focus { border: 2px solid #8B5A2B; }
    QComboBox { font-size: 10pt; min-height: 28px; }
    QComboBox::drop-down { border: none; width: 20px; }
    QComboBox::down-arrow { image: none; border-left: 4px solid transparent; border-right: 4px solid transparent; border-top: 4px solid #8B5A2B; margin-right: 6px; }
    QPushButton { background-color: #8B5A2B; color: #F5EBE0; border: none; border-radius: 5px; padding: 10px 20px; font-weight: bold; font-size: 10pt; }
    QPushButton:hover { background-color: #9B8068; }
    QPushButton:pressed { background-color: #5D4037; }
    QPushButton#btnAjouter { background-color: #8B9B6A; }
    QPushButton#btnAjouter:hover { background-color: #9BAB7A; }
    QPushButton#btnModifier { background-color: #8B5A2B; }
    QPushButton#btnModifier:hover { background-color: #9B8068; }
    QPushButton#btnSupprimer { background-color: #5D4037; }
    QPushButton#btnSupprimer:hover { background-color: #6D4C41; }
    QPushButton#btnVider, QPushButton#btnRechercher, QPushButton#btnResetRecherche, QPushButton#btnTriPrixCroissant, QPushButton#btnTriPrixDecroissant { background-color: #C9B59A; color: #3D2817; }
    QPushButton#btnVider:hover, QPushButton#btnRechercher:hover, QPushButton#btnResetRecherche:hover, QPushButton#btnTriPrixCroissant:hover, QPushButton#btnTriPrixDecroissant:hover { background-color: #D9C5AA; }
    QTableWidget { background-color: #FFFFFF; alternate-background-color: #F5EBE0; border: 2px solid #C9B59A; border-radius: 5px; gridline-color: #C9B59A; color: #3D2817; }
    QTableWidget::item:selected { background-color: #8B5A2B; color: #F5EBE0; }
    QHeaderView::section { background-color: #8B5A2B; color: #F5EBE0; padding: 6px; border: none; font-weight: bold; font-size: 10pt; }
    QLabel#headerTitle { font-size: 22px; font-weight: bold; color: #3D2817; padding: 15px; background-color: #C9B59A; border-radius: 8px; margin: 10px; border: 2px solid #8B5A2B; }
    QFrame#statCard { background-color: #FFFFFF; border: 2px solid #8B5A2B; border-radius: 8px; padding: 15px; }
    QLabel#statValue { font-size: 28px; font-weight: bold; color: #5D4037; }
    QLabel#statText { font-size: 14px; color: #8B5A2B; font-weight: 500; }
    QLabel#alerteLabel { background-color: #FFF3CD; color: #856404; padding: 10px; border-radius: 5px; border: 1px solid #FFEAA7; font-weight: bold; }
    QProgressBar { border: 2px solid #C9B59A; border-radius: 5px; text-align: center; background-color: #FFFFFF; color: #3D2817; }
    QProgressBar::chunk { background-color: #8B9B6A; border-radius: 3px; }
    QPushButton#btnGenererPDF, QPushButton#btnApercuPDF, QPushButton#btnEnvoyerEmail { background-color: #8B9B6A; }
    QPushButton#btnGenererPDF:hover, QPushButton#btnApercuPDF:hover, QPushButton#btnEnvoyerEmail:hover { background-color: #9BAB7A; }
    QPushButton#btnGenererStats, QPushButton#btnExporterStats { background-color: #C9B59A; color: #3D2817; }
    QPushButton#btnGenererStats:hover, QPushButton#btnExporterStats:hover { background-color: #D9C5AA; }
  </string>
 </property>
